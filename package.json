{
  "name": "mozi",
  "version": "2.0.0",
  "description": "MOZI — Autonomous Agent Operating System",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:unit:report": "vitest run --config vitest.unit.config.ts --reporter=default --reporter=json --outputFile=reports/unit.json",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:report": "vitest run --config vitest.integration.config.ts --reporter=default --reporter=json --outputFile=reports/integration.json",
    "test:provider-compat:smoke": "NO_UPDATE_NOTIFIER=1 PROVIDER_COMPAT_MODE=smoke pnpm exec vitest run --config vitest.integration.config.ts tests/integration/provider-compat-matrix.integration.test.ts",
    "test:provider-compat:full": "NO_UPDATE_NOTIFIER=1 PROVIDER_COMPAT_MODE=full pnpm exec vitest run --config vitest.integration.config.ts tests/integration/provider-compat-matrix.integration.test.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:e2e:report": "vitest run --config vitest.e2e.config.ts --reporter=default --reporter=json --outputFile=reports/e2e.json",
    "test:e2e:web": "node scripts/web-ui-smoke.mjs",
    "test:ci": "pnpm test:unit && pnpm test:integration && pnpm test:e2e && pnpm test:e2e:web",
    "verify:prompt-contract": "node scripts/prompt-contract.mjs",
    "verify:pre-merge": "pnpm verify:prompt-contract && pnpm typecheck && MOZI_E2E_LLM=scripted pnpm test:unit && pnpm build:all && pnpm test:integration && pnpm test:e2e && pnpm test:e2e:web --skip-build && pnpm gate:e2e",
    "verify:complex-task-gate": "node scripts/complex-task-gate.mjs",
    "replay:generate": "node scripts/failure-replay-generate.mjs",
    "mozi": "node dist/cli.js",
    "test:watch": "vitest",
    "watchdog": "node dist/watchdog/main.js",
    "desktop:dev": "pnpm --filter mozi-desktop dev",
    "desktop:build": "pnpm --filter mozi-desktop build",
    "desktop:generate-icon": "node scripts/generate-desktop-icon.mjs",
    "verify:brand-assets": "node scripts/sync-brand-assets.mjs --check",
    "verify:public-export": "node scripts/verify-public-export.mjs",
    "desktop:stage-node": "node scripts/stage-desktop-node.mjs",
    "desktop:prepare-runtime": "node scripts/prepare-desktop-runtime.mjs",
    "desktop:prepare-package": "pnpm build:all && pnpm desktop:stage-node && pnpm desktop:prepare-runtime",
    "desktop:pack:mac": "pnpm desktop:prepare-package && pnpm --filter mozi-desktop pack:mac",
    "desktop:dist:mac": "pnpm desktop:prepare-package && pnpm --filter mozi-desktop dist:mac",
    "desktop:test:packaged": "node scripts/desktop-packaged-matrix.mjs",
    "ui:dev": "pnpm --filter mozi-ui dev",
    "ui:build": "pnpm --filter mozi-ui build",
    "verify:ui-bundle": "node scripts/check-ui-bundle.mjs",
    "build:all": "tsup && pnpm --filter mozi-ui build && pnpm verify:ui-bundle",
    "start:all": "tsup && node dist/cli.js start --build-ui",
    "version:bump": "node scripts/release.mjs",
    "release:cut": "node scripts/release.mjs --all",
    "release:manifest": "node scripts/release-supply-chain.mjs",
    "release:verify-artifacts": "node scripts/release-supply-chain.mjs --publishable",
    "gate:e2e": "MOZI_E2E_LLM=scripted vitest run --testTimeout=90000 scripts/gate-e2e.test.ts",
    "gate:e2e:real": "MOZI_E2E_REAL_MODEL=1 vitest run --testTimeout=300000 scripts/gate-e2e-real.test.ts"
  },
  "keywords": [
    "agent",
    "llm",
    "autonomous"
  ],
  "author": "Chaojie + Mozi",
  "packageManager": "pnpm@10.29.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.46",
    "@ai-sdk/mcp": "^1.0.21",
    "@ai-sdk/openai": "^3.0.30",
    "@ai-sdk/openai-compatible": "^2.0.30",
    "@anthropic-ai/sdk": "^0.78.0",
    "@clack/prompts": "^1.0.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.2.0",
    "@lancedb/lancedb": "^0.27.0",
    "@larksuiteoapi/node-sdk": "^1.60.0",
    "@line/bot-sdk": "^11.0.0",
    "@mariozechner/pi-agent-core": "^0.60.0",
    "@mariozechner/pi-ai": "^0.60.0",
    "@mariozechner/pi-coding-agent": "^0.60.0",
    "@mattermost/client": "^11.6.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@slack/socket-mode": "^2.0.6",
    "@slack/web-api": "^7.15.1",
    "ai": "^6.0.97",
    "better-sqlite3": "^12.6.2",
    "croner": "^10.0.1",
    "discord.js": "^14.26.3",
    "fastify": "^5.7.4",
    "irc-framework": "^4.14.0",
    "js-yaml": "^4.1.1",
    "matrix-js-sdk": "^41.3.0",
    "pino": "^10.3.1",
    "smol-toml": "^1.6.0",
    "telegraf": "^4.16.3",
    "tmi.js": "^1.8.5",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.0",
    "@types/tmi.js": "^1.8.6",
    "dotenv": "^17.3.1",
    "playwright": "^1.58.2",
    "vitest": "^4.0.18"
  },
  "bin": {
    "mozi": "dist/cli.js"
  }
}
