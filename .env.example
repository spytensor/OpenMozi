# MOZI Configuration
# Copy this file to .env and fill in your API keys

# LLM Provider (pick at least one)
# MINIMAX_API_KEY=your-minimax-key      # Default provider, generous free tier
# OPENAI_API_KEY=your-openai-key
# ANTHROPIC_API_KEY=your-anthropic-key
# GOOGLE_API_KEY=your-google-key
# DEEPSEEK_API_KEY=your-deepseek-key
# GROQ_API_KEY=your-groq-key
# MOONSHOT_API_KEY=your-moonshot-key

# Telegram Bot (optional)
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Vector Memory (optional, defaults to keyword search)
# EMBEDDING_PROVIDER=ollama              # ollama (local/free) | openai | minimax
# EMBEDDING_MODEL=nomic-embed-text       # Model name for embedding provider

# Web Search (optional)
# TAVILY_API_KEY=your-tavily-key
# Optional editor-grade local Office rendering (DOCX/XLSX/PPTX).
# Generate a stable secret, then run: docker compose --profile office up -d
# OFFICE_DOCUMENT_SERVER_URL=http://localhost:8082
# OFFICE_DOCUMENT_SERVER_INTERNAL_URL=http://onlyoffice
# OFFICE_STORAGE_BASE_URL=http://mozi:9210
# ONLYOFFICE_JWT_SECRET=
